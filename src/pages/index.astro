---
import { YFlow } from "@use-compose/ui";
import ProjectList from "../projects/components/ProjectList.astro";
import Layout from "../layouts/Layout.astro";
import type { Project } from "../types/index.ts";

const response = await fetch(
  `${import.meta.env.PUBLIC_API_URL}/content/projects`,
);
console.log("📟 - response → ", response);
const data = response.ok ? await response.json() : [];
console.log("📟 - data → ", data);
const projects: Project[] = Array.isArray(data) ? data : [];
console.log("📟 - projects → ", projects);
const hasProjects = projects && projects.length > 0;
console.log("📟 - hasProjects → ", hasProjects);
---

<Layout>
  {
    !hasProjects ? (
      <YFlow client:only="vue">
        <p>No projects found.</p>
      </YFlow>
    ) : (
      <ProjectList projects={projects} />
    )
  }
</Layout>
